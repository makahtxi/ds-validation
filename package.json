{
  "name": "ds-validation",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "audit": "node packages/cli/dist/index.js audit",
    "init": "node packages/cli/dist/index.js init",
    "report": "node packages/cli/dist/index.js report"
  },
  "packageManager": "npm@10.9.2",
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}